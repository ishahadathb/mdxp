{
  "name": "mdxp",
  "version": "0.1.0",
  "description": "Turn any directory of Markdown into a fast, browsable HTML explorer. Renders on demand, live-reloads, supports Mermaid and full-text search, and writes nothing to your files.",
  "type": "module",
  "bin": {
    "mdxp": "bin/mdxp.js"
  },
  "files": [
    "bin",
    "src",
    "assets/app.css",
    "assets/app.js",
    "assets/favicon.svg"
  ],
  "scripts": {
    "start": "node bin/mdxp.js",
    "demo": "node bin/mdxp.js sample",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "preversion": "npm test",
    "postversion": "git push && git push --tags",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "markdown",
    "markdown-viewer",
    "md",
    "explorer",
    "mermaid",
    "docs",
    "documentation",
    "cli",
    "live-reload",
    "markdown-to-html"
  ],
  "author": "Biplob <shahadat.biplob@cefalo.com> (https://github.com/ishahadathb)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishahadathb/mdxp.git"
  },
  "homepage": "https://github.com/ishahadathb/mdxp#readme",
  "bugs": {
    "url": "https://github.com/ishahadathb/mdxp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.4.1",
    "sanitize-html": "2.17.0"
  }
}
